@{
    Layout = "_Layout";
    ViewData["Title"] = "Trang chủ";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

@await Html.PartialAsync("_Carousel")

@* <p>Vai trò hiện tại: @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p> *@

<section class="mt-4">
    <div class="container">
        <h2 class="text-center">Khám phá miền Trung</h2>
        <p class="text-center">Những điểm đến hấp dẫn không thể bỏ lỡ</p>

        <div class="row">
            <div class="col-md-4">
                <div class="card tour-card">
                    <img src="/images/danang.jpg" class="card-img-top" alt="Đà Nẵng">
                    <div class="card-body text-center">
                        <h5 class="card-title text-warning">ĐÀ NẴNG</h5>
                        <a asp-controller="Location" asp-action="Danang1" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card tour-card">
                    <img src="/images/hue.jpg" class="card-img-top" alt="Huế">
                    <div class="card-body text-center">
                        <h5 class="card-title text-warning">HUẾ</h5>
                        <a asp-controller="Location" asp-action="Hue1" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card tour-card">
                    <img src="/images/hoian.jpg" class="card-img-top" alt="Hội An">
                    <div class="card-body text-center">
                        <h5 class="card-title text-warning">HỘI AN</h5>
                        <a asp-controller="Location" asp-action="Hoian1" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card tour-card">
                    <img src="/images/phongnha.jpg" class="card-img-top" alt="Quảng Bình">
                    <div class="card-body text-center">
                        <h5 class="card-title text-warning">QUẢNG BÌNH</h5>
                        <a asp-controller="Location" asp-action="Quangbinh1" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card tour-card">
                    <img src="/images/nhatrang.jpg" class="card-img-top" alt="Nha Trang">
                    <div class="card-body text-center">
                        <h5 class="card-title text-warning">NHA TRANG</h5>
                        <a asp-controller="Location" asp-action="Nhatrang1" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card tour-card">
                    <img src="/images/phuyen.jpg" class="card-img-top" alt="Phú Yên">
                    <div class="card-body text-center">
                        <h5 class="card-title text-warning">PHÚ YÊN</h5>
                        <a asp-controller="Location" asp-action="Phuyen1" class="btn btn-primary">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <section>
        <div class="swiper-container">
            <h2 class="text-center">Bài viết gần đây</h2>
            <div class="swiper-wrapper">
                @if (ViewBag.RecentPosts != null && ((List<TourismWeb.Models.Post>)ViewBag.RecentPosts).Any())
                {
                    @foreach (var post in ViewBag.RecentPosts)
                    {
                        <div class="swiper-slide">
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.PostId" class="text-decoration-none text-dark">
                                <div class="slider-card clickable-card">
                                    <div class="slider-image-wrapper">
                                        <img src="@(string.IsNullOrEmpty(post.ImageUrl) ? "/images/default-postImage.png" : post.ImageUrl)" alt="@post.Title">
                                        <span class="slider-category @GetCategoryClass(post.TypeOfPost)">@post.TypeOfPost</span>
                                    </div>
                                    <div class="slider-content">
                                        <div class="article-author">
                                            <span class="author-name">@post.User.FullName</span>
                                        </div>
                                        <h3 class="slider-title">@post.Title</h3>
                                        <p class="slider-description">
                                            @(post.Content.Length > 100 ? post.Content.Substring(0, 100) + "..." : post.Content)
                                        </p>
                                        <div class="slider-location">📍 @post.Spot.Name</div>
                                        <div class="article-interactions">
                                            <div class="interaction-item me-3 d-inline-block">
                                                <span class="interaction-icon">❤️</span>
                                                <span>0</span>
                                            </div>
                                            <div class="interaction-item d-inline-block">
                                                <span class="interaction-icon">💬</span>
                                                <span>0</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="swiper-slide">
                        <div class="slider-card">
                            <div class="slider-content text-center">
                                <p>Chưa có bài viết nào.</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <!-- Chấm tròn pagination -->
            <div class="swiper-pagination"></div>
        </div>
    </section>
    
    @await Html.PartialAsync("_Review")
    

    <section class="guide-wrapper">
        <div class="guide-section">
            <div class="container">
                <div class="text-center mb-4">
                    <h2><b>Cẩm Nang Du Lịch Miền Trung từ A - Z</b></h2>
                    <div class="divider">
                        <hr>
                        <div class="dots">
                            <span class="dot"></span>
                            <span class="dot"></span>
                            <span class="dot"></span>
                        </div>
                        <hr>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="guide-container">
            <div class="container">
                
                <div class="row">
                    @if (ViewBag.GuidebookPosts != null && ViewBag.GuidebookPosts.Count > 0)
                    {
                        @foreach (var post in ViewBag.GuidebookPosts)
                        {
                            <div class="col-md-4 mb-4">
                                <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.PostId" class="destination-card text-decoration-none text-dark">
                                    <div class="card h-100 clickable-card">
                                        <img src="@post.ImageUrl" class="card-img-top" alt="@post.Title">
                                        <div class="card-body">
                                            <h5 class="card-title"><b>@post.Title</b></h5>
                                            <p class="guide-date">@post.CreatedAt.ToString("dd MMMM, yyyy")</p>
                                            <p class="card-text">@(post.Content.Length > 100 ? post.Content.Substring(0, 100) + "..." : post.Content)</p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <p>Chưa có bài viết cẩm nang nào.</p>
                        </div>
                    }
                    <div class="d-flex justify-content-end mb-3">
                        <a asp-controller="Posts" asp-action="Category" asp-route-type="Cẩm nang" class="btn btn-outline-primary">Xem tất cả</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</section>

@functions {
    public string GetCategoryClass(string typeOfPost)
    {
        return typeOfPost switch
        {
            "Cẩm nang" => "category-cam-nang",
            "Trải nghiệm" => "category-trai-nghiem",
            "Địa điểm" => "category-dia-diem",
            _ => "category-default"
        };
    }
}